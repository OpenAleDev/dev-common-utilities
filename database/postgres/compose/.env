DATABASE_CONTAINER_NAME="test-compose-postgres"

POSTGRES_IMAGE="postgres:15"

POSTGRES_USER="${DATABASE_CONTAINER_NAME}_user"
POSTGRES_PASSWORD="${DATABASE_CONTAINER_NAME}_password"
POSTGRES_DB="${DATABASE_CONTAINER_NAME}_db"
OUTPUT_PORT=9999

VOLUME_DATA_PATH="../_volume/pgdata"
INIT_SCRIPTS_PATH="../_volume/init-sql"

